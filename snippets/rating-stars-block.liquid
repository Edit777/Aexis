{% assign rating_id = 'rating-stars-' | append: section.id | append: '-' | append: block.id %}
<div id="{{ rating_id }}" class="aex-rating-stars" style="--rating:{{ block.settings.rating | default: 5 }};--star-color:{{ block.settings.star_color | default: '#f6b01e' }};--bg-star-color:{{ block.settings.bg_star_color | default: '#ddd' }};--font-size:{{ block.settings.size | divided_by: 10.0 | default: 1.4 }}rem;--margin-top: {{ block.settings.margin_top | divided_by: 10.0 | default: 0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 | default: 0 }}rem;" {% if block_attributes %}{{ block.shopify_attributes }}{% endif %}>
  {% if block.settings.scroll_id != blank %}<a href="{{ block.settings.scroll_id }}">{% endif %}
  <span class="aex-rating-stars__line">
    <span class="aex-rating-stars__stack">
      <span class="aex-rating-stars__underlay">★★★★★</span>
      <span class="aex-rating-stars__overlay">★★★★★</span>
    </span>
    {% if block.settings.label != blank %}<span class="aex-rating-stars__label">{{ block.settings.label }}</span>{% endif %}
  </span>
  {% if block.settings.scroll_id != blank %}</a>{% endif %}
</div>

<style>
  #{{ rating_id }} { margin-top: var(--margin-top); margin-bottom: var(--margin-bottom); font-size: var(--font-size); text-align: {{ block.settings.alignment | default: 'left' }}; }
  #{{ rating_id }} .aex-rating-stars__line { display: inline-flex; align-items: center; gap: .45em; line-height: 1; }
  #{{ rating_id }} .aex-rating-stars__stack { position: relative; display: inline-block; letter-spacing: .15em; }
  #{{ rating_id }} .aex-rating-stars__underlay { color: var(--bg-star-color); }
  #{{ rating_id }} .aex-rating-stars__overlay { color: var(--star-color); position: absolute; left: 0; top: 0; white-space: nowrap; overflow: hidden; width: calc((var(--rating) / 5) * 100%); }
</style>
