{% comment %}
  Renders a discount code input in the cart drawer footer.

  Accepts:
  - block: {Object} Block object (settings drive all labels and messages)

  Usage:
  {% render 'cart-discount-field', block: block %}
{% endcomment %}

<cart-discount-field
  data-success-message="{{ block.settings.success_message | escape }}"
  data-error-message="{{ block.settings.error_message | escape }}"
>
  <div
    class="cart-discount-field"
    {{ block.shopify_attributes }}
  >
    <form class="cart-discount-field__form" novalidate>
      <div class="cart-discount-field__row">
        <div class="field">
          <input
            class="field__input cart-discount-field__input"
            type="text"
            id="CartDiscountCode"
            name="discount"
            placeholder="{{ block.settings.input_placeholder | escape }}"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="characters"
            spellcheck="false"
          >
          <label class="field__label" for="CartDiscountCode">
            {{ block.settings.input_placeholder }}
          </label>
        </div>
        <button type="submit" class="button cart-discount-field__submit">
          {{ block.settings.button_label }}
        </button>
      </div>
      <p class="cart-discount-field__feedback cart-discount-field__error" hidden aria-live="polite"></p>
      <p class="cart-discount-field__feedback cart-discount-field__success" hidden aria-live="polite"></p>
    </form>

    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <ul
        class="cart-discount-field__applied discounts list-unstyled"
        aria-label="{{ 'customer.order.discount' | t }}"
      >
        {%- for discount in cart.cart_level_discount_applications -%}
          <li class="discounts__discount">
            <span class="svg-wrapper">
              {{- 'icon-discount.svg' | inline_asset_content -}}
            </span>
            {{ discount.title | escape }}
            (-{{ discount.total_allocated_amount | money }})
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</cart-discount-field>
