{% liquid
  assign product_ref = upsell_product
  assign product_index = upsell_index
  assign preselected = false
  assign featured_image = blank
  assign description = blank
  assign percentage_discount = 0
  assign fixed_discount = 0

  case product_index
    when 1
      assign preselected = block.settings.prdouct_1_preselected
      assign featured_image = block.settings.product_1_image
      assign description = block.settings.product_1_desc
      assign percentage_discount = block.settings.product_1_percentage_discount | plus: 0
      assign fixed_discount = block.settings.product_1_fixed_amount_discount | times: 100.0
    when 2
      assign preselected = block.settings.prdouct_2_preselected
      assign featured_image = block.settings.product_2_image
      assign description = block.settings.product_2_desc
      assign percentage_discount = block.settings.product_2_percentage_discount | plus: 0
      assign fixed_discount = block.settings.product_2_fixed_amount_discount | times: 100.0
    when 3
      assign preselected = block.settings.prdouct_3_preselected
      assign featured_image = block.settings.product_3_image
      assign description = block.settings.product_3_desc
      assign percentage_discount = block.settings.product_3_percentage_discount | plus: 0
      assign fixed_discount = block.settings.product_3_fixed_amount_discount | times: 100.0
  endcase

  assign discount_multiplier = 100.0 | minus: percentage_discount | divided_by: 100.0
  assign initial_variant = product_ref.first_available_variant
  assign compare_price = initial_variant.compare_at_price
  if compare_price == blank or compare_price <= initial_variant.price
    assign compare_price = initial_variant.price
  endif
  assign final_price = initial_variant.price | times: discount_multiplier | minus: fixed_discount
  if final_price < 0
    assign final_price = 0
  endif

  assign card_image = featured_image
  if card_image == blank
    assign card_image = product_ref.featured_image
  endif

  assign selected_in_cart = false
  for cart_item in cart.items
    if cart_item.variant_id == initial_variant.id
      assign selected_in_cart = true
      break
    endif
  endfor

  assign render_item = true
  if block.settings.style == 'add_button' and block.settings.hide_in_cart_items and selected_in_cart
    assign render_item = false
  endif
%}

{% if render_item %}
  <article
    class="cart-drawer-upsells__item"
    data-upsell-item
    data-product-id="{{ product_ref.id }}"
    data-initial-variant-id="{{ initial_variant.id }}"
    data-selected="{% if selected_in_cart or preselected %}true{% else %}false{% endif %}"
    data-in-cart="{% if selected_in_cart %}true{% else %}false{% endif %}"
    data-preselected="{% if preselected %}true{% else %}false{% endif %}"
    data-discount-percent="{{ percentage_discount }}"
    data-discount-fixed-cents="{{ fixed_discount | round }}"
  >
    <div class="cart-drawer-upsells__item-inner">
      {% if block.settings.show_images and card_image != blank %}
        <div class="cart-drawer-upsells__image-wrap">
          <img
            class="cart-drawer-upsells__image"
            src="{{ card_image | image_url: width: 400 }}"
            alt="{{ card_image.alt | escape }}"
            loading="lazy"
            width="120"
            height="120"
          >
        </div>
      {% endif %}

      <div class="cart-drawer-upsells__content">
        <div class="cart-drawer-upsells__heading-row">
          <h3 class="cart-drawer-upsells__title">
            {% if block.settings.title_link %}<a href="{{ product_ref.url }}">{% endif %}
              {{ product_ref.title }}
            {% if block.settings.title_link %}</a>{% endif %}
          </h3>

          {% if block.settings.price_position == 'next_to_title' %}
            <p class="cart-drawer-upsells__price" data-upsell-price>
              <span data-upsell-price-final>{{ final_price | money }}</span>
              <span data-upsell-price-compare {% if block.settings.hide_compare_price or compare_price <= final_price %}hidden{% endif %}>{{ compare_price | money }}</span>
            </p>
          {% endif %}
        </div>

        {% if description != blank %}
          <div class="cart-drawer-upsells__description rte">{{ description }}</div>
        {% endif %}

        {% if block.settings.show_variant_picker and product_ref.has_only_default_variant == false %}
          <div class="cart-drawer-upsells__variants" data-upsell-variant-picker>
            {% for option in product_ref.options_with_values %}
              <label class="visually-hidden" for="UpsellOption-{{ section.id }}-{{ block.id }}-{{ product_index }}-{{ option.position }}">{{ option.name }}</label>
              <div class="select select--small no-background color-{{ settings.pickers_color_scheme }} gradient">
                <select
                  id="UpsellOption-{{ section.id }}-{{ block.id }}-{{ product_index }}-{{ option.position }}"
                  class="select__select"
                  data-option-position="{{ option.position }}"
                >
                  {% assign option_index = option.position | minus: 1 %}
                  {% assign initial_option_value = initial_variant.options[option_index] %}
                  {% for value in option.values %}
                    <option
                      value="{{ value | escape }}"
                      {% if initial_option_value == value %}selected{% endif %}
                    >
                      {{ value }}
                    </option>
                  {% endfor %}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if block.settings.price_position == 'separate' %}
          <p class="cart-drawer-upsells__price cart-drawer-upsells__price--separate" data-upsell-price>
            <span data-upsell-price-final>{{ final_price | money }}</span>
            <span data-upsell-price-compare {% if block.settings.hide_compare_price or compare_price <= final_price %}hidden{% endif %}>{{ compare_price | money }}</span>
          </p>
        {% endif %}

        <div class="cart-drawer-upsells__actions cart-drawer-upsells__actions--{{ block.settings.btn_position }}">
          {% if block.settings.style == 'toggle_switch' %}
            <button
              type="button"
              class="cart-drawer-upsells__toggle"
              data-upsell-control
              aria-pressed="{% if selected_in_cart or preselected %}true{% else %}false{% endif %}"
              aria-label="{{ product_ref.title | escape }}"
            >
              <span class="cart-drawer-upsells__toggle-track"><span class="cart-drawer-upsells__toggle-thumb"></span></span>
            </button>
          {% else %}
            <button
              type="button"
              class="button button--secondary cart-drawer-upsells__add-btn"
              data-upsell-control
            >
              {{ block.settings.add_btn_label | strip_html }}
            </button>
          {% endif %}
        </div>
      </div>
    </div>

    <script type="application/json" data-upsell-variants>
      [
        {% for variant in product_ref.variants %}
          {
            "id": {{ variant.id }},
            "available": {{ variant.available | json }},
            "price": {{ variant.price }},
            "compare_at_price": {{ variant.compare_at_price | default: 0 }},
            "options": {{ variant.options | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    </script>
  </article>
{% endif %}
