{% liquid
  assign enabled_goal_count = 0
  assign highest_goal = 0
  assign next_goal = 0
  assign next_goal_text = blank

  assign is_quantity = false
  if block.settings.goal_type == 'quantity'
    assign is_quantity = true
  endif

  if is_quantity
    assign goal_multiplier = 1.0
    assign goal_max_reference = items_count
  else
    assign goal_multiplier = 100.00
    assign goal_max_reference = cart.items_subtotal_price
  endif

  assign goal_1_value = block.settings.goal_1_amount | times: goal_multiplier
  assign goal_2_value = block.settings.goal_2_amount | times: goal_multiplier
  assign goal_3_value = block.settings.goal_3_amount | times: goal_multiplier

  if block.settings.enable_goal_1 and goal_1_value > 0
    assign enabled_goal_count = enabled_goal_count | plus: 1
    if goal_1_value > highest_goal
      assign highest_goal = goal_1_value
    endif
  endif

  if block.settings.enable_goal_2 and goal_2_value > 0
    assign enabled_goal_count = enabled_goal_count | plus: 1
    if goal_2_value > highest_goal
      assign highest_goal = goal_2_value
    endif
  endif

  if block.settings.enable_goal_3 and goal_3_value > 0
    assign enabled_goal_count = enabled_goal_count | plus: 1
    if goal_3_value > highest_goal
      assign highest_goal = goal_3_value
    endif
  endif

  assign bar_progress = 0
  if highest_goal > 0
    assign bar_progress = goal_max_reference | times: 100.00 | divided_by: highest_goal
  endif

  assign all_goals_reached = false
  if bar_progress >= 100.00
    assign all_goals_reached = true
    assign bar_progress = 100
  endif

  if block.settings.enable_goal_1 and goal_1_value > 0
    assign goal_1_position = goal_1_value | times: 100.00 | divided_by: highest_goal
    if goal_max_reference < goal_1_value
      if next_goal == 0 or goal_1_value < next_goal
        assign next_goal = goal_1_value
        assign next_goal_text = block.settings.goal_1_text
      endif
    endif
  endif

  if block.settings.enable_goal_2 and goal_2_value > 0
    assign goal_2_position = goal_2_value | times: 100.00 | divided_by: highest_goal
    if goal_max_reference < goal_2_value
      if next_goal == 0 or goal_2_value < next_goal
        assign next_goal = goal_2_value
        assign next_goal_text = block.settings.goal_2_text
      endif
    endif
  endif

  if block.settings.enable_goal_3 and goal_3_value > 0
    assign goal_3_position = goal_3_value | times: 100.00 | divided_by: highest_goal
    if goal_max_reference < goal_3_value
      if next_goal == 0 or goal_3_value < next_goal
        assign next_goal = goal_3_value
        assign next_goal_text = block.settings.goal_3_text
      endif
    endif
  endif

  assign next_goal_text_downcase = next_goal_text | downcase
%}

{% capture goal_difference_html %}
  {% if is_quantity %}
    {{ next_goal | minus: items_count | round }}
  {% else %}
    <span>{{ next_goal | minus: cart.items_subtotal_price | money_without_trailing_zeros }}</span>
  {% endif %}
{% endcapture %}

{% if enabled_goal_count > 0 and highest_goal > 0 %}
  <div class="cart-progress cart-checkpoints color-{{ block.settings.color_scheme }} gradient" style="--mobile-text-size: {{ block.settings.labels_mobile_text_size | divided_by: 10.0 }}rem;--desktop-text-size: {{ block.settings.labels_desktop_text_size | divided_by: 10.0 }}rem;--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;" {{ block.shopify_attributes }}>
    <p class="cart-progress__text">
      {% if all_goals_reached == false and next_goal > 0 and next_goal_text != blank %}
        {{ block.settings.progress_message | replace: '[amount]', goal_difference_html | replace: '[next_goal]', next_goal_text | replace: '[next_goal_lowercase]', next_goal_text_downcase }}
      {% else %}
        {{ block.settings.success_message }}
      {% endif %}
    </p>
    <div class="cart-progress__bar">
      <div class="cart-progress__bar__progress" style="width: {{ bar_progress }}%;">&nbsp</div>
      {% if block.settings.enable_goal_1 and goal_1_value > 0 %}
        <div class="cart-progress__bar__badge cart-checkpoints__icon{% if goal_max_reference >= goal_1_value %} is-unlocked{% endif %}" style="--position:{{ goal_1_position }}%;">
          {% if block.settings.goal_1_icon != blank %}
            {% render 'material-icon', icon: block.settings.goal_1_icon, filled: block.settings.goal_1_icon_filled and goal_max_reference >= goal_1_value %}
          {% else %}
            <span class="svg-wrapper">{% render 'icon-checkmark' %}</span>
          {% endif %}
          {% if block.settings.goal_1_label != blank %}
            <span class='cart-checkpoints__label custom-font-size'>
              {{ block.settings.goal_1_label }}
            </span>
          {% endif %}
        </div>
      {% endif %}
      {% if block.settings.enable_goal_2 and goal_2_value > 0 %}
        <div class="cart-progress__bar__badge cart-checkpoints__icon{% if goal_max_reference >= goal_2_value %} is-unlocked{% endif %}" style="--position:{{ goal_2_position }}%;">
          {% if block.settings.goal_2_icon != blank %}
            {% render 'material-icon', icon: block.settings.goal_2_icon, filled: block.settings.goal_2_icon_filled and goal_max_reference >= goal_2_value %}
          {% else %}
            <span class="svg-wrapper">{% render 'icon-checkmark' %}</span>
          {% endif %}
          {% if block.settings.goal_2_label != blank %}
            <span class='cart-checkpoints__label custom-font-size'>
              {{ block.settings.goal_2_label }}
            </span>
          {% endif %}
        </div>
      {% endif %}
      {% if block.settings.enable_goal_3 and goal_3_value > 0 %}
        <div class="cart-progress__bar__badge cart-checkpoints__icon{% if goal_max_reference >= goal_3_value %} is-unlocked{% endif %}" style="--position:{{ goal_3_position }}%;">
          {% if block.settings.goal_3_icon != blank %}
            {% render 'material-icon', icon: block.settings.goal_3_icon, filled: block.settings.goal_3_icon_filled and goal_max_reference >= goal_3_value %}
          {% else %}
            <span class="svg-wrapper">{% render 'icon-checkmark' %}</span>
          {% endif %}
          {% if block.settings.goal_3_label != blank %}
            <span class='cart-checkpoints__label custom-font-size'>
              {{ block.settings.goal_3_label }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
